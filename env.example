# Supabase
# Consigue estas credenciales en tu proyecto de Supabase:
# 1. Ve a https://supabase.com/dashboard
# 2. Selecciona tu proyecto
# 3. Ve a Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://tu-proyecto.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="tu-anon-key-aqui"
SUPABASE_SERVICE_ROLE_KEY="tu-service-role-key-aqui"

# NextAuth
# Genera un secret ejecutando: openssl rand -base64 32
AUTH_SECRET="tu-secret-super-secreto-cambialo-en-produccion"
AUTH_URL="http://localhost:3000"
# Nota: En NextAuth v5, las variables cambiaron de NEXTAUTH_* a AUTH_*
# También puedes usar trustHost: true en la configuración para desarrollo

# Google OAuth
# Consigue tus credenciales en: https://console.cloud.google.com/
GOOGLE_CLIENT_ID="tu-google-client-id"
GOOGLE_CLIENT_SECRET="tu-google-client-secret"

# Facebook OAuth
# Consigue tus credenciales en: https://developers.facebook.com/
FACEBOOK_CLIENT_ID="tu-facebook-app-id"
FACEBOOK_CLIENT_SECRET="tu-facebook-app-secret"

# Strava OAuth
# Consigue tus credenciales en: https://www.strava.com/settings/api
STRAVA_CLIENT_ID="tu-strava-client-id"
STRAVA_CLIENT_SECRET="tu-strava-client-secret"

# Mercado Pago
# Consigue tus credenciales en: https://www.mercadopago.com/developers
MERCADOPAGO_ACCESS_TOKEN="tu-access-token-de-mercadopago"
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY="tu-public-key-de-mercadopago"

# Configuración de Suscripción
NEXT_PUBLIC_SUBSCRIPTION_PRICE="999.00"
NEXT_PUBLIC_CURRENCY="ARS"

# AWS S3 para almacenamiento de imágenes
# Nota: Usamos el prefijo HS_ porque AWS_ está restringido en Netlify
HS_AWS_ACCESS_KEY_ID="tu-access-key-id"
HS_AWS_SECRET_ACCESS_KEY="tu-secret-access-key"
HS_AWS_REGION="us-east-1"
HS_AWS_S3_BUCKET="happy-sapiens-avatars"
HS_AWS_CLOUDFRONT_DOMAIN="tu-distribucion.cloudfront.net"  # Opcional, si no se usa CloudFront se usará URL directa de S3

# ZeptoMail SMTP (envío de correos)
# Consigue tus credenciales en: https://www.zoho.com/zeptomail/
ZEPTOMAIL_SMTP_HOST="smtp.zeptomail.com"
ZEPTOMAIL_SMTP_PORT="587"
ZEPTOMAIL_SMTP_USER="emailapi"
ZEPTOMAIL_SMTP_PASSWORD="tu-api-key-de-zeptomail"
ZEPTOMAIL_FROM_EMAIL="noreply@tudominio.com"
ZEPTOMAIL_FROM_NAME="Happy Sapiens"